<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.45.2/dist/apexcharts.min.js"></script>
<style>@keyframes spin{to{transform:rotate(360deg)}}</style>

<div class="p-6">
  <div class="mb-6 flex items-center justify-between" id="page-header">
    <div id="page-title" <% unless RenderDashboard.configuration.show_title %>style="display:none"<% end %>>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-slate-100">Render Metrics</h1>
      <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">CPU, memory, and disk usage across all services</p>
    </div>
    <div class="flex items-center gap-2">
      <button id="title-toggle" class="p-1.5 rounded-md text-gray-400 dark:text-slate-500 hover:text-gray-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="Toggle title">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M3 2h2v5h6V2h2v12h-2V9H5v5H3V2z"/></svg>
      </button>
      <button id="scale-toggle" class="p-1.5 rounded-md text-gray-400 dark:text-slate-500 hover:text-gray-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="Toggle full scale (0–100%)">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v12M5 5l3-3 3 3M5 11l3 3 3-3"/></svg>
      </button>
      <div class="flex gap-0.5 bg-slate-100 dark:bg-slate-800 rounded-lg p-1" id="col-picker">
        <button data-cols="1" class="col-btn px-1.5 py-1 rounded-md transition-colors" title="1 column">
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><rect x="2" y="2" width="12" height="12" rx="1.5"/></svg>
        </button>
        <button data-cols="2" class="col-btn px-1.5 py-1 rounded-md transition-colors" title="2 columns">
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="2" width="6" height="12" rx="1.5"/><rect x="9" y="2" width="6" height="12" rx="1.5"/></svg>
        </button>
        <button data-cols="3" class="col-btn px-1.5 py-1 rounded-md transition-colors" title="3 columns">
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><rect x="0.5" y="2" width="4" height="12" rx="1"/><rect x="6" y="2" width="4" height="12" rx="1"/><rect x="11.5" y="2" width="4" height="12" rx="1"/></svg>
        </button>
        <button data-cols="4" class="col-btn px-1.5 py-1 rounded-md transition-colors" title="4 columns">
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="2" width="3" height="12" rx="0.75"/><rect x="4.33" y="2" width="3" height="12" rx="0.75"/><rect x="8.66" y="2" width="3" height="12" rx="0.75"/><rect x="13" y="2" width="3" height="12" rx="0.75"/></svg>
        </button>
      </div>
      <div class="w-px h-5 bg-slate-200 dark:bg-slate-700"></div>
      <% if @grouped_services.is_a?(Array) && @grouped_services.length > 1 %>
        <select id="project-filter"
                class="text-xs font-medium rounded-lg px-3 py-1.5 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-700 dark:text-slate-300 focus:outline-none focus:ring-2 focus:ring-indigo-500/50">
          <option value="">All projects</option>
          <% @grouped_services.each do |project_name, _| %>
            <option value="<%= project_name %>"><%= project_name %></option>
          <% end %>
        </select>
      <% end %>
      <div class="flex gap-1 bg-slate-100 dark:bg-slate-800 rounded-lg p-1" id="time-range-picker">
        <button data-hours="1"   class="time-btn px-3 py-1.5 text-xs font-medium rounded-md transition-colors">1h</button>
        <button data-hours="6"   class="time-btn px-3 py-1.5 text-xs font-medium rounded-md transition-colors">6h</button>
        <button data-hours="24"  class="time-btn px-3 py-1.5 text-xs font-medium rounded-md transition-colors active">24h</button>
        <button data-hours="168" class="time-btn px-3 py-1.5 text-xs font-medium rounded-md transition-colors">7d</button>
      </div>
    </div>
  </div>

  <% if @error.present? %>
    <div class="p-4 bg-red-50 dark:bg-red-900/30 border-l-4 border-red-400 dark:border-red-500 text-red-700 dark:text-red-300 rounded mb-6">
      <strong>Error:</strong> <%= @error %>
    </div>
  <% end %>

  <% if @services.empty? && @error.blank? %>
    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/30 border-l-4 border-yellow-400 dark:border-yellow-500 text-yellow-700 dark:text-yellow-300 rounded">
      No services found. Make sure <code>RENDER_API_KEY</code> is configured.
    </div>
  <% end %>

  <div id="services-container" class="space-y-8">
    <% @grouped_services.each do |project_name, services| %>
      <div class="project-group" data-project="<%= project_name %>">
        <% if @grouped_services.length > 1 %>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 border-b border-gray-200 dark:border-slate-700 pb-2 mb-4"><%= project_name %></h2>
        <% end %>
        <div class="services-grid grid grid-cols-1 gap-6">
          <% services.each do |svc| %>
            <% svc_id   = svc["id"] %>
            <% details  = svc["serviceDetails"] || {} %>
            <% svc_type = svc["type"] || "unknown" %>
            <% svc_plan = details["plan"] || "—" %>
            <% svc_region = details["region"] || "—" %>
            <% svc_env  = details["env"] || "" %>
            <% disk     = details["disk"] %>

            <div class="card p-5" data-service-id="<%= svc_id %>" data-has-disk="<%= disk.present? %>">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-slate-100"><%= svc["name"] %></h3>
                  <div class="flex flex-wrap gap-3 mt-1">
                    <span class="text-xs text-gray-500 dark:text-slate-400"><%= svc_type %></span>
                    <% if svc_env.present? %>
                      <span class="text-xs text-gray-500 dark:text-slate-400"><%= svc_env %></span>
                    <% end %>
                    <span class="text-xs text-gray-500 dark:text-slate-400"><%= svc_plan %></span>
                    <span class="text-xs text-gray-500 dark:text-slate-400"><%= svc_region %></span>
                    <% if disk.present? %>
                      <span class="inline-flex items-center gap-1 text-xs text-emerald-600 dark:text-emerald-400">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
                        <%= disk["name"] %> &middot; <%= disk["sizeGB"] %> GB &middot; <code class="text-[10px]"><%= disk["mountPath"] %></code>
                      </span>
                    <% end %>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <button class="pin-btn p-1 rounded-md transition-colors text-gray-300 dark:text-slate-600 hover:text-amber-500 dark:hover:text-amber-400" data-pin-id="<%= svc_id %>" title="Pin to top">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/></svg>
                  </button>
                  <span class="text-xs font-mono text-gray-400 dark:text-slate-500"><%= svc_id %></span>
                </div>
              </div>

              <div class="grid grid-cols-1 lg:grid-cols-2 <%= disk.present? ? 'xl:grid-cols-3' : '' %> gap-4">
                <div>
                  <h4 class="text-sm font-medium text-gray-600 dark:text-slate-300 mb-2">CPU</h4>
                  <div id="cpu-chart-<%= svc_id %>" class="chart-container" style="min-height: 360px;">
                    <div class="flex items-center justify-center h-[360px] text-sm text-gray-400 dark:text-slate-500">Loading...</div>
                  </div>
                </div>
                <div>
                  <h4 class="text-sm font-medium text-gray-600 dark:text-slate-300 mb-2">Memory</h4>
                  <div id="memory-chart-<%= svc_id %>" class="chart-container" style="min-height: 360px;">
                    <div class="flex items-center justify-center h-[360px] text-sm text-gray-400 dark:text-slate-500">Loading...</div>
                  </div>
                </div>
                <% if disk.present? %>
                  <div>
                    <h4 class="text-sm font-medium text-gray-600 dark:text-slate-300 mb-2">Disk</h4>
                    <div id="disk-chart-<%= svc_id %>" class="chart-container" style="min-height: 360px;">
                      <div class="flex items-center justify-center h-[360px] text-sm text-gray-400 dark:text-slate-500">Loading...</div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% content_for :page_specific_js do %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const DATA_URL   = '<%= render_metrics_data_path %>';
  const SERVICE_IDS = <%= raw @services.map { |s| s["id"] }.to_json %>;
  const SERVICES_WITH_DISK = new Set(<%= raw @services.select { |s| s.dig("serviceDetails", "disk").present? }.map { |s| s["id"] }.to_json %>);

  const charts = {};
  var urlParams = new URLSearchParams(window.location.search);
  var titleDefault = <%= RenderDashboard.configuration.show_title ? 'true' : 'false' %>;
  let currentHours = parseInt(urlParams.get('hours')) || 24;
  let currentCols = Math.min(4, Math.max(1, parseInt(urlParams.get('cols')) || 1));
  let fullScale = urlParams.get('scale') === 'full';
  let pinnedIds = new Set((urlParams.get('pin') || '').split(',').filter(Boolean));
  var initProject = urlParams.get('project') || '';
  var initTitle = urlParams.has('title') ? urlParams.get('title') === '1' : titleDefault;

  function updateURL() {
    var params = new URLSearchParams();
    if (currentHours !== 24) params.set('hours', currentHours);
    if (currentCols !== 1) params.set('cols', currentCols);
    if (fullScale) params.set('scale', 'full');
    if (pinnedIds.size > 0) params.set('pin', Array.from(pinnedIds).join(','));
    var pf = document.getElementById('project-filter');
    if (pf && pf.value) params.set('project', pf.value);
    var te = document.getElementById('page-title');
    var titleVisible = te && te.style.display !== 'none';
    if (titleVisible !== titleDefault) params.set('title', titleVisible ? '1' : '0');
    var qs = params.toString();
    history.replaceState(null, '', qs ? '?' + qs : window.location.pathname);
  }

  const isDark = () => document.documentElement.classList.contains('dark');

  function chartColors() {
    return {
      text:   isDark() ? '#94a3b8' : '#6b7280',
      grid:   isDark() ? '#334155' : '#e5e7eb',
      bg:     isDark() ? '#1e293b' : '#ffffff',
      tooltip: isDark() ? 'dark' : 'light'
    };
  }

  function baseOptions(seriesData, unit, colors) {
    const c = chartColors();
    return {
      series: seriesData,
      chart: {
        type: 'area',
        height: 360,
        fontFamily: 'Inter, system-ui, sans-serif',
        background: 'transparent',
        toolbar: { show: false },
        zoom: { enabled: false },
        animations: { enabled: true, easing: 'easeinout', speed: 400 }
      },
      colors: colors,
      fill: {
        type: 'gradient',
        gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05, stops: [0, 90, 100] }
      },
      dataLabels: { enabled: false },
      stroke: { curve: 'smooth', width: 2 },
      xaxis: {
        type: 'datetime',
        labels: {
          style: { colors: c.text, fontSize: '10px' },
          datetimeUTC: false
        },
        axisBorder: { show: false },
        axisTicks: { show: false }
      },
      yaxis: {
        labels: {
          style: { colors: c.text, fontSize: '11px' },
          formatter: function(val) {
            if (val == null) return '';
            if (unit === '%') return val.toFixed(0) + '%';
            if (unit === 'GB') return val.toFixed(2) + ' GB';
            if (unit === 'MB') return val.toFixed(0) + ' MB';
            return val.toFixed(1) + (unit ? ' ' + unit : '');
          }
        },
        min: 0,
        max: (fullScale && unit === '%') ? 100 : undefined
      },
      tooltip: {
        theme: c.tooltip,
        x: { format: 'HH:mm  dd MMM' },
        y: {
          formatter: function(val) {
            if (val == null) return '—';
            if (unit === '%') return val.toFixed(1) + '%';
            if (unit === 'GB') return val.toFixed(3) + ' GB';
            if (unit === 'MB') return val.toFixed(1) + ' MB';
            return val.toFixed(2) + (unit ? ' ' + unit : '');
          }
        }
      },
      grid: {
        borderColor: c.grid,
        strokeDashArray: 4,
        padding: { left: 5, right: 5 }
      },
      legend: { show: false },
      markers: { size: 0, hover: { size: 4 } }
    };
  }

  function parseSeries(dataArr) {
    if (!Array.isArray(dataArr) || dataArr.length === 0) return { series: [], unit: '' };

    const unit = dataArr[0].unit || '';
    const series = dataArr.map(function(ts) {
      const label = (ts.labels || []).map(function(l) { return l.value; }).join(' ');
      const data = (ts.values || []).map(function(v) {
        return [new Date(v.timestamp).getTime(), v.value];
      });
      return { name: label || 'value', data: data };
    });
    return { series: series, unit: unit };
  }

  function renderChart(containerId, dataArr, limitArr, colors) {
    const parsed = parseSeries(dataArr);
    let series = parsed.series;
    let unit = parsed.unit;

    // Add limit as a dashed line if available
    if (Array.isArray(limitArr) && limitArr.length > 0) {
      const limitParsed = parseSeries(limitArr);
      if (limitParsed.series.length > 0) {
        const limitSeries = limitParsed.series[0];
        limitSeries.name = 'Limit';
        series = series.concat([limitSeries]);
      }
    }

    if (series.length === 0) {
      const el = document.getElementById(containerId);
      if (el) el.innerHTML =
        '<div class="flex flex-col items-center justify-center h-[360px] gap-1.5">' +
          '<svg class="w-5 h-5 text-gray-300 dark:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>' +
          '<span class="text-sm text-gray-400 dark:text-slate-500">No recent activity</span>' +
        '</div>';
      return null;
    }

    // Convert to percentage if we have both usage and limit
    if (series.length >= 2 && series[series.length - 1].name === 'Limit') {
      const usageSeries = series.slice(0, -1);
      const limitData = series[series.length - 1].data;

      if (limitData.length > 0) {
        const limitValue = limitData[0][1];
        if (limitValue > 0) {
          usageSeries.forEach(function(s) {
            s.data = s.data.map(function(point) {
              return [point[0], (point[1] / limitValue) * 100];
            });
          });
          unit = '%';
          series = usageSeries;
        }
      }
    }

    const opts = baseOptions(series, unit, colors);

    // Tweak stroke for limit line
    if (series.length > 1 && series[series.length - 1].name === 'Limit') {
      opts.stroke = {
        curve: 'smooth',
        width: series.map(function(_, i) { return i === series.length - 1 ? 1 : 2; }),
        dashArray: series.map(function(_, i) { return i === series.length - 1 ? 5 : 0; })
      };
      opts.fill = {
        type: series.map(function(_, i) { return i === series.length - 1 ? 'solid' : 'gradient'; }),
        gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05, stops: [0, 90, 100] },
        opacity: series.map(function(_, i) { return i === series.length - 1 ? 0 : 1; })
      };
    }

    const el = document.getElementById(containerId);
    if (!el) return null;
    el.innerHTML = '';

    const chart = new ApexCharts(el, opts);
    chart.render();
    return chart;
  }

  const retryTimers = {};

  function randomRetrySeconds() {
    return Math.floor(30 + Math.random() * 60);
  }

  function showRetryCountdown(serviceId, reason, seconds) {
    const chartTypes = ['cpu', 'memory'];
    if (SERVICES_WITH_DISK.has(serviceId)) chartTypes.push('disk');

    let remaining = seconds || randomRetrySeconds();
    const label = reason === 'timeout' ? 'Timed out' : 'Rate limited';

    chartTypes.forEach(function(type) {
      const el = document.getElementById(type + '-chart-' + serviceId);
      if (el) {
        el.innerHTML =
          '<div class="flex flex-col items-center justify-center h-[360px] gap-2">' +
            '<svg style="animation:spin 1s linear infinite;height:1.25rem;width:1.25rem;color:#818cf8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">' +
              '<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>' +
              '<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>' +
            '</svg>' +
            '<span class="text-sm text-gray-400 dark:text-slate-500 retry-msg">' + label + ' — retrying in ' + remaining + 's</span>' +
          '</div>';
      }
    });

    if (retryTimers[serviceId]) clearInterval(retryTimers[serviceId]);
    retryTimers[serviceId] = setInterval(function() {
      remaining--;
      if (remaining <= 0) {
        clearInterval(retryTimers[serviceId]);
        delete retryTimers[serviceId];
        return;
      }
      chartTypes.forEach(function(type) {
        const msg = document.querySelector('#' + type + '-chart-' + CSS.escape(serviceId) + ' .retry-msg');
        if (msg) msg.textContent = label + ' — retrying in ' + remaining + 's';
      });
    }, 1000);
  }

  function loadService(serviceId, hours) {
    const url = DATA_URL + '?resource=' + encodeURIComponent(serviceId) + '&hours=' + hours;

    fetch(url, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
      .then(function(r) {
        if (r.status === 429) {
          return r.json().then(function(body) { body._retryReason = 'rate_limit'; return body; });
        }
        if (r.status === 504) {
          return r.json().then(function(body) { body._retryReason = 'timeout'; return body; });
        }
        return r.json();
      })
      .then(function(data) {
        if (data._retryReason) {
          var reason = data._retryReason;
          var delay = (data.retry_after ? (data.retry_after + Math.random() * 3) : randomRetrySeconds()) * 1000;
          console.warn('Metrics ' + reason + ' for ' + serviceId + (data.error ? ': ' + data.error : '') + ' — retrying in ' + Math.round(delay / 1000) + 's');
          showRetryCountdown(serviceId, reason, Math.round(delay / 1000));
          setTimeout(function() { loadService(serviceId, hours); }, delay);
          return;
        }

        if (data.error) {
          ['cpu', 'memory'].forEach(function(type) {
            const el = document.getElementById(type + '-chart-' + serviceId);
            if (el) el.innerHTML = '<div class="flex items-center justify-center h-[360px] text-sm text-red-400">' + data.error + '</div>';
          });
          return;
        }

        var cpuEmpty = !Array.isArray(data.cpu) || data.cpu.length === 0;
        var memEmpty = !Array.isArray(data.memory) || data.memory.length === 0;
        var diskEmpty = !data.disk_usage || data.disk_usage.length === 0;

        if (cpuEmpty && memEmpty && diskEmpty) {
          var emptyHtml =
            '<div class="flex flex-col items-center justify-center h-[360px] gap-1.5">' +
              '<svg class="w-5 h-5 text-gray-300 dark:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>' +
              '<span class="text-sm text-gray-400 dark:text-slate-500">No recent activity</span>' +
            '</div>';
          ['cpu', 'memory'].forEach(function(type) {
            var el = document.getElementById(type + '-chart-' + serviceId);
            if (el) el.innerHTML = emptyHtml;
          });
          if (SERVICES_WITH_DISK.has(serviceId)) {
            var diskEl = document.getElementById('disk-chart-' + serviceId);
            if (diskEl) diskEl.innerHTML = emptyHtml;
          }
          return;
        }

        if (charts[serviceId]) {
          Object.values(charts[serviceId]).forEach(function(c) { if (c) c.destroy(); });
        }
        charts[serviceId] = {};

        charts[serviceId].cpu = renderChart(
          'cpu-chart-' + serviceId, data.cpu, data.cpu_limit,
          ['#8b5cf6', '#a78bfa']
        );
        charts[serviceId].memory = renderChart(
          'memory-chart-' + serviceId, data.memory, data.memory_limit,
          ['#6366f1', '#818cf8']
        );

        if (SERVICES_WITH_DISK.has(serviceId) && data.disk_usage) {
          charts[serviceId].disk = renderChart(
            'disk-chart-' + serviceId, data.disk_usage, data.disk_capacity,
            ['#10b981', '#34d399']
          );
        }
      })
      .catch(function(err) {
        console.error('Failed to load metrics for', serviceId, err);
      });
  }

  const loadedServices = new Set();

  function visibleServiceIds() {
    const filter = document.getElementById('project-filter');
    const selected = filter ? filter.value : '';
    if (!selected) return SERVICE_IDS;

    var ids = [];
    document.querySelectorAll('.project-group[data-project="' + selected + '"] [data-service-id]').forEach(function(el) {
      ids.push(el.dataset.serviceId);
    });
    return ids;
  }

  function loadAll(hours) {
    visibleServiceIds().forEach(function(id) { loadService(id, hours); loadedServices.add(id); });
  }

  // Title toggle
  var titleEl = document.getElementById('page-title');
  var titleToggle = document.getElementById('title-toggle');
  if (titleToggle && titleEl) {
    titleEl.style.display = initTitle ? '' : 'none';
    function syncTitleBtn() {
      var visible = titleEl.style.display !== 'none';
      titleToggle.classList.toggle('text-gray-600', visible);
      titleToggle.classList.toggle('dark:text-slate-300', visible);
      titleToggle.classList.toggle('text-gray-400', !visible);
      titleToggle.classList.toggle('dark:text-slate-500', !visible);
    }
    syncTitleBtn();
    titleToggle.addEventListener('click', function() {
      titleEl.style.display = titleEl.style.display === 'none' ? '' : 'none';
      syncTitleBtn();
      updateURL();
    });
  }

  // Scale toggle
  var scaleToggle = document.getElementById('scale-toggle');
  function syncScaleBtn() {
    if (!scaleToggle) return;
    scaleToggle.classList.toggle('text-gray-600', fullScale);
    scaleToggle.classList.toggle('dark:text-slate-300', fullScale);
    scaleToggle.classList.toggle('text-gray-400', !fullScale);
    scaleToggle.classList.toggle('dark:text-slate-500', !fullScale);
  }
  syncScaleBtn();
  if (scaleToggle) {
    scaleToggle.addEventListener('click', function() {
      fullScale = !fullScale;
      syncScaleBtn();
      Object.keys(charts).forEach(function(sid) {
        if (charts[sid]) Object.values(charts[sid]).forEach(function(c) { if (c) c.destroy(); });
      });
      loadedServices.clear();
      loadAll(currentHours);
      updateURL();
    });
  }

  // Column layout picker
  var colClasses = {
    1: ['grid-cols-1'],
    2: ['grid-cols-1', 'lg:grid-cols-2'],
    3: ['grid-cols-1', 'lg:grid-cols-2', 'xl:grid-cols-3'],
    4: ['grid-cols-1', 'lg:grid-cols-2', 'xl:grid-cols-4']
  };
  var allColClasses = ['grid-cols-1', 'lg:grid-cols-2', 'xl:grid-cols-3', 'xl:grid-cols-4'];
  var colPicker = document.getElementById('col-picker');

  function setColumns(n) {
    document.querySelectorAll('.services-grid').forEach(function(grid) {
      allColClasses.forEach(function(c) { grid.classList.remove(c); });
      colClasses[n].forEach(function(c) { grid.classList.add(c); });
    });
  }

  function activateColBtn(n) {
    if (!colPicker) return;
    colPicker.querySelectorAll('.col-btn').forEach(function(b) {
      b.classList.remove('bg-white', 'dark:bg-slate-700', 'text-gray-900', 'dark:text-slate-100', 'shadow-sm');
      b.classList.add('text-gray-500', 'dark:text-slate-400');
    });
    var target = colPicker.querySelector('[data-cols="' + n + '"]');
    if (target) {
      target.classList.add('bg-white', 'dark:bg-slate-700', 'text-gray-900', 'dark:text-slate-100', 'shadow-sm');
      target.classList.remove('text-gray-500', 'dark:text-slate-400');
    }
  }
  if (colPicker) {
    colPicker.querySelectorAll('.col-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentCols = parseInt(btn.dataset.cols);
        activateColBtn(currentCols);
        setColumns(currentCols);
        updateURL();
      });
    });
  }
  activateColBtn(currentCols);
  setColumns(currentCols);

  // Project filter
  var projectFilter = document.getElementById('project-filter');
  function applyProjectFilter(selected) {
    document.querySelectorAll('.project-group').forEach(function(group) {
      group.style.display = (!selected || group.dataset.project === selected) ? '' : 'none';
    });
  }
  if (projectFilter) {
    if (initProject) {
      projectFilter.value = initProject;
      applyProjectFilter(initProject);
    }
    projectFilter.addEventListener('change', function() {
      applyProjectFilter(this.value);
      visibleServiceIds().forEach(function(id) {
        if (!loadedServices.has(id)) { loadService(id, currentHours); loadedServices.add(id); }
      });
      updateURL();
    });
  }

  // Time range picker
  const picker = document.getElementById('time-range-picker');
  function activateTimeBtn(hours) {
    if (!picker) return;
    picker.querySelectorAll('.time-btn').forEach(function(b) {
      b.classList.remove('bg-white', 'dark:bg-slate-700', 'text-gray-900', 'dark:text-slate-100', 'shadow-sm');
      b.classList.add('text-gray-500', 'dark:text-slate-400');
    });
    var target = picker.querySelector('[data-hours="' + hours + '"]');
    if (target) {
      target.classList.add('bg-white', 'dark:bg-slate-700', 'text-gray-900', 'dark:text-slate-100', 'shadow-sm');
      target.classList.remove('text-gray-500', 'dark:text-slate-400');
    }
  }
  if (picker) {
    picker.querySelectorAll('.time-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentHours = parseInt(btn.dataset.hours);
        activateTimeBtn(currentHours);
        loadedServices.clear();
        loadAll(currentHours);
        updateURL();
      });
    });
  }
  activateTimeBtn(currentHours);

  // Pin management
  function syncPinButtons() {
    document.querySelectorAll('.pin-btn').forEach(function(btn) {
      var pinned = pinnedIds.has(btn.dataset.pinId);
      btn.classList.toggle('text-amber-500', pinned);
      btn.classList.toggle('dark:text-amber-400', pinned);
      btn.classList.toggle('text-gray-300', !pinned);
      btn.classList.toggle('dark:text-slate-600', !pinned);
      var card = btn.closest('.card');
      if (card) {
        card.classList.toggle('ring-1', pinned);
        card.classList.toggle('ring-amber-400/50', pinned);
        card.classList.toggle('dark:ring-amber-500/30', pinned);
      }
    });
  }

  function reorderPinned() {
    document.querySelectorAll('.services-grid').forEach(function(grid) {
      var cards = Array.from(grid.querySelectorAll('.card[data-service-id]'));
      cards.sort(function(a, b) {
        var ap = pinnedIds.has(a.dataset.serviceId) ? 0 : 1;
        var bp = pinnedIds.has(b.dataset.serviceId) ? 0 : 1;
        return ap - bp;
      });
      cards.forEach(function(card) { grid.appendChild(card); });
    });
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.pin-btn');
    if (!btn) return;
    var id = btn.dataset.pinId;
    if (pinnedIds.has(id)) { pinnedIds.delete(id); } else { pinnedIds.add(id); }
    syncPinButtons();
    reorderPinned();
    updateURL();
  });

  syncPinButtons();
  reorderPinned();

  // Initial load
  loadAll(currentHours);
});
</script>
<% end %>
